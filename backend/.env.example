# 服务器配置
# 监听端口（默认：3000）
PORT=3000

# 绑定地址（默认：0.0.0.0，表示所有网络接口）
HOSTNAME=0.0.0.0

# 运行环境（development | production）
NODE_ENV=production

# 最大并发图片数
NOVA_TASK_CONCURRENCY=50

# ============================================
# 队列与限流配置（运行时读取，修改 .env 后通常无需重启）
# ============================================

# 全局最大待处理任务数（排队中 + 生成中），达到后返回 503 QUEUE_FULL
NOVA_MAX_QUEUE_SIZE=200

# 限流窗口长度（毫秒）
NOVA_RATE_LIMIT_WINDOW_MS=60000

# 单 IP 在一个窗口内最多创建多少个任务，超过返回 429 RATE_LIMITED
NOVA_RATE_LIMIT_MAX_REQUESTS_PER_IP=10

# 单 API Key 在一个窗口内最多创建多少个任务，超过返回 429 RATE_LIMITED
NOVA_RATE_LIMIT_MAX_REQUESTS_PER_API_KEY=10

# 单 IP 最多同时拥有多少个待处理任务，超过返回 429 TOO_MANY_PENDING_TASKS
NOVA_MAX_PENDING_TASKS_PER_IP=20

# 单 API Key 最多同时拥有多少个待处理任务，超过返回 429 TOO_MANY_PENDING_TASKS
NOVA_MAX_PENDING_TASKS_PER_API_KEY=20

# 队列满/限流时返回给客户端的 Retry-After 秒数
NOVA_RATE_LIMIT_RETRY_AFTER_SECONDS=60

# ============================================
# 提示词广场配置
# ============================================

# 提示词广场模式：1=常驻（直接显示） 2=私密（需密码验证，点七下标题） 3=关闭（完全隐藏）
# 修改 .env 文件后实时生效，无需重启服务
PROMPT_GALLERY_MODE=1
PROMPT_GALLERY_PASSWORD=8848

# ============================================
# 多用户后端(阶段 1+):PostgreSQL + Redis + MinIO + sub2api 代验
# 与 docker-compose.yml 的默认凭证对应,生产务必替换
# ============================================

# PostgreSQL 连接串(业务元数据)
DATABASE_URL=postgres://nova:nova_dev_pw@localhost:5432/nova

# Redis 连接串(token 代验缓存)
REDIS_URL=redis://localhost:6379

# sub2api 地址:既用于代验身份(/api/v1/user/profile),也用于生图代理(/v1/*)
SUB2API_BASE_URL=https://sub2api.example.com

# token 代验缓存秒数(默认 60)
TOKEN_CACHE_TTL=60

# MinIO / S3 兼容对象存储(图片/GIF 本体)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=nova_minio
S3_SECRET_KEY=nova_minio_dev_pw
S3_BUCKET=nova
S3_REGION=us-east-1
# 预签名读取的公开访问域名(可选,留空则用 S3_ENDPOINT)
S3_PUBLIC_BASE_URL=

# ============================================
# 每用户云端图片上限(素材库 / 生图历史各自独立计数)
# 达到上限后该类新图片不再上云(仍保留本地 IndexedDB),前端提示用户先导出/备份后清理。
# 内容相同的图片按 SHA-256 去重,不重复占用存储,也不计入上限。
# 取值须为正整数,非法/缺省时回退 50。
# ============================================
USER_ASSET_LIMIT=50
USER_GENERATION_LIMIT=50