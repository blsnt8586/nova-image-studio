{
  "name": "nova-image-backend",
  "version": "3.1.0",
  "private": true,
  "description": "Nova Image 后端 - 任务队列和 API 服务器",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
