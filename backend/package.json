    "ioredis": "^5.4.1",
    "next": "^16.2.4",
    "pg": "^8.13.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.34.5",
    "undici": "^8.2.0",
    "ws": "^8.20.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-istanbul": "3.2.6",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.30.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "vitest": "^3.2.4"
