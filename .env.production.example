# Nova Image Studio 生产环境变量模板
# 复制为 .env.production 后按实际值填写。切勿把填好真实凭证的 .env.production 提交到 git。
#   cp .env.production.example .env.production

# ===== 服务自身 =====
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
# 宿主机映射端口(docker-compose.prod.yml 用),与反代 upstream 对应
NOVA_HOST_PORT=3000

# 并发与队列(按机器配置酌情调整)
NOVA_TASK_CONCURRENCY=50
NOVA_MAX_QUEUE_SIZE=200
NOVA_RATE_LIMIT_WINDOW_MS=60000
NOVA_RATE_LIMIT_MAX_REQUESTS_PER_IP=10
NOVA_RATE_LIMIT_MAX_REQUESTS_PER_API_KEY=10
NOVA_MAX_PENDING_TASKS_PER_IP=20
NOVA_MAX_PENDING_TASKS_PER_API_KEY=20
NOVA_RATE_LIMIT_RETRY_AFTER_SECONDS=60

# ===== 提示词广场 =====
# 1=常驻 2=私密(需密码,点七下标题) 3=关闭
PROMPT_GALLERY_MODE=1
PROMPT_GALLERY_PASSWORD=改成你自己的密码

# ===== 依赖服务连接(关键!容器内访问宿主机服务用 host.docker.internal)=====
# 你服务器上已有的 PostgreSQL。把用户名/密码/库名换成实际值。
DATABASE_URL=postgres://用户名:密码@host.docker.internal:5432/nova

# 已有的 Redis
REDIS_URL=redis://host.docker.internal:6379

# 你的 sub2api(https 带域名)。代验身份 + 生图代理都走它。
SUB2API_BASE_URL=https://你的sub2api域名
TOKEN_CACHE_TTL=60

# 已有的 MinIO / S3。S3_BUCKET 必须事先存在(server.js 不自动创建)。
S3_ENDPOINT=http://host.docker.internal:9000
S3_ACCESS_KEY=你的MinIO_AccessKey
S3_SECRET_KEY=你的MinIO_SecretKey
S3_BUCKET=nova
S3_REGION=us-east-1
# 预签名读取对外暴露的地址。生产强烈建议配成 https 公网可达域名,
# 否则浏览器在 https 的 sub2api iframe 里加载 http 图片会被 mixed-content 拦截。
S3_PUBLIC_BASE_URL=https://你的MinIO对外域名

# ===== 每用户云端图片上限 =====
USER_ASSET_LIMIT=50
USER_GENERATION_LIMIT=50
