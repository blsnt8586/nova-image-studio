# Nova Image Studio 生产环境变量模板
# 复制为 .env.production 后按实际值填写。切勿把填好真实凭证的 .env.production 提交到 git。
#   cp .env.production.example .env.production

# ===== 服务自身 =====
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
# 宿主机映射端口(docker-compose.prod.yml 用),openresty 反代 upstream 指向它。
# 若 3000 被占,改成别的(如 3100)。
NOVA_HOST_PORT=3000

# 并发与队列(按机器配置酌情调整)
NOVA_TASK_CONCURRENCY=50
NOVA_MAX_QUEUE_SIZE=200
NOVA_RATE_LIMIT_WINDOW_MS=60000
NOVA_RATE_LIMIT_MAX_REQUESTS_PER_IP=10
NOVA_RATE_LIMIT_MAX_REQUESTS_PER_API_KEY=10
NOVA_MAX_PENDING_TASKS_PER_IP=20
NOVA_MAX_PENDING_TASKS_PER_API_KEY=20
NOVA_RATE_LIMIT_RETRY_AFTER_SECONDS=60

# ===== 提示词广场 =====
# 1=常驻 2=私密(需密码,点七下标题) 3=关闭
PROMPT_GALLERY_MODE=1
PROMPT_GALLERY_PASSWORD=改成你自己的密码

# ===== 依赖服务连接 =====
# PG/Redis 只有后端容器用 → 走 1panel-network 内部地址(容器名 + 内部端口)。
# nova 与它们同在 1panel-network,所以用容器名直连,不用宿主机的非标准端口。
# PG:容器名 postgresql,内部端口 5432,sub2api 用的超级用户 root。库名 nova(下面手动建)。
DATABASE_URL=postgres://root:Zjf200014@postgresql:5432/nova

# Redis:容器名 redis,内部端口 6379,无密码。用 db1 避免和 sub2api 抢 key 空间。
REDIS_URL=redis://redis:6379/1

# 你的 sub2api(https 带域名)。代验身份 + 生图代理都走它。
SUB2API_BASE_URL=https://你的sub2api域名
TOKEN_CACHE_TTL=60

# ===== MinIO / S3 =====
# ⚠️ 关键:S3_ENDPOINT 会被直接写进返回给【浏览器】的图片预签名 URL(SigV4 把 host 算进签名)。
# 所以它必须是浏览器在 https iframe 里能访问的【公网 https 域名】,不能用 http://minio:9000。
# 后端和浏览器必须用同一个 endpoint,签名才有效。先在 1Panel 给 MinIO 配好域名再填这里。
# (注:S3_PUBLIC_BASE_URL 在当前代码里未被使用,填了也无效,真正生效的是 S3_ENDPOINT。)
S3_ENDPOINT=https://你给minio配的域名
S3_ACCESS_KEY=minio
S3_SECRET_KEY=zjf200014
S3_BUCKET=nova
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=

# ===== 每用户云端图片上限 =====
USER_ASSET_LIMIT=50
USER_GENERATION_LIMIT=50
